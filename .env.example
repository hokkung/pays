# Database
DATABASE_URL=postgresql+asyncpg://pays:pays@localhost:5432/pays

# Auth (single-user API token — change this!)
API_TOKEN=changeme

# Server
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# HTTP client
HTTP_TIMEOUT_SECONDS=30

# Scheduler (cron expressions)
FETCH_NEWS_CRON=0 * * * *
REFRESH_PRICES_CRON=0 * * * *
REFRESH_FX_CRON=0 * * * *

# Data source URLs (defaults are fine)
FRANKFURTER_BASE_URL=https://api.frankfurter.app
GOOGLE_NEWS_BASE_URL=https://news.google.com/rss/search

# Optional API keys (not required for basic operation)
# FRED_API_KEY=your_fred_api_key_here
